#!/bin/sh
set -eu

compat_root=/opt/vulkan-rtx-compat
export RTX_VULKAN_COMPAT_ENABLE_LAYER=1
export VK_KHRONOS_PROFILES_PROFILE_NAME=VP_RTX_driver_compat_generated
export VK_KHRONOS_PROFILES_SIMULATE_CAPABILITIES=SIMULATE_PROPERTIES_BIT
export VK_KHRONOS_PROFILES_DEBUG_REPORTS=DEBUG_REPORT_ERROR_BIT
export VK_KHRONOS_PROFILES_PROFILE_DIRS="$compat_root/profiles${VK_KHRONOS_PROFILES_PROFILE_DIRS:+:$VK_KHRONOS_PROFILES_PROFILE_DIRS}"
export XDG_DATA_DIRS="$compat_root/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"

echo "RTX Vulkan compatibility profile enabled: maxMemoryAllocationSize=4292870144" >&2

exec /opt/venvs/robolab/bin/python "$@"
